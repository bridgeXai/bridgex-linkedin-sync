{
  "manifest_version": 3,
  "name": "BridgeX LinkedIn Sync",
  "version": "0.1.0",
  "description": "从当前 LinkedIn 标签页读取姓名与链接，一键同步到飞书多维表格。",
  "permissions": ["activeTab", "storage", "contextMenus", "scripting"],
  "host_permissions": ["https://open.feishu.cn/*", "https://openrouter.ai/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "同步 LinkedIn 行为到飞书",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
